{
  "name": "djadwal-monorepo",
  "private": true,
  "scripts": {
    "dev": "pnpm recursive run dev",
    "build": "pnpm recursive run build",
    "start:web": "pnpm --filter @djadwal/web run dev",
    "start:api": "pnpm --filter @djadwal/api run start",
    "start:desktop": "pnpm --filter @djadwal/desktop run start",
    "lint": "pnpm recursive run lint"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "typescript": "^5.5.3",
    "eslint": "^9.9.1"
  }
}
