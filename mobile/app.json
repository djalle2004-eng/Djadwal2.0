      "predictiveBackGestureEnabled": false,
      "package": "com.hussainali.djadwal"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "b68fb124-4e21-49a5-b7dc-fab213d925c9"
      }
    }
  }
}